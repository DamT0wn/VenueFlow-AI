# ══════════════════════════════════════════════════════════════════════════════
# VenueFlow AI — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to source control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local: provided by docker-compose.yml (redis://localhost:6379)
# Production: Cloud Memorystore or Upstash — mount via GCP Secret Manager
REDIS_URL=redis://localhost:6379

# ── Firebase Admin (backend) ──────────────────────────────────────────────────
# Download from Firebase Console → Project Settings → Service Accounts
# Paste the entire JSON as a single-line string (escape quotes)
FIREBASE_PROJECT_ID=demo-venueflow
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase Emulator (set automatically by docker-compose.yml)
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
PUBSUB_EMULATOR_HOST=localhost:8085

# ── Google Cloud Pub/Sub ──────────────────────────────────────────────────────
PUBSUB_PROJECT_ID=demo-venueflow
PUBSUB_TOPIC=venue-alerts-development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=100
RATE_LIMIT_WRITE_MAX=20

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ══════════════════════════════════════════════════════════════════════════════
# Frontend (apps/web) — All NEXT_PUBLIC_ vars are exposed to the browser
# ══════════════════════════════════════════════════════════════════════════════

# ── Google Maps ───────────────────────────────────────────────────────────────
# IMPORTANT: Restrict this key to your domain in GCP Console → APIs & Services
# → Credentials → Application restrictions: HTTP referrers
# Add: localhost:3000/*, venueflow.app/*, *.venueflow.app/*
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# ── Firebase Client SDK ───────────────────────────────────────────────────────
# From Firebase Console → Project Settings → Your apps → Web app → Config
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-venueflow.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-venueflow
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-venueflow.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# ── Firebase Cloud Messaging ──────────────────────────────────────────────────
# From Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key_here

# ── Firebase Emulator (set to 'true' to use local emulators) ─────────────────
NEXT_PUBLIC_USE_EMULATOR=true

# ── Google Analytics 4 ───────────────────────────────────────────────────────
# From GA4 → Admin → Data Streams → Web → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── API URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Production app URL (for OpenGraph metadata)
NEXT_PUBLIC_APP_URL=https://venueflow.app
